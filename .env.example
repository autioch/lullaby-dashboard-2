# Firebase configuration for the dashboard
# Copy this file to .env and fill in your project values.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=
APP_PASSWORD=

# HMAC key that signs the HttpOnly session cookie. The content-edit write API
# routes verify this cookie, so writes fail without it. Use a long random string.
SESSION_SECRET=

# Optional (local dev only): set to true to bypass the password gate.
# Leave false/absent in production.
PUBLIC_SKIP_AUTH=false