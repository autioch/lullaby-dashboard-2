    "astro": "^6.4.4",
    "firebase": "^12.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "firebase-admin": "^13.10.0",
