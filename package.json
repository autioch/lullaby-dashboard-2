{
  "name": "launchpad",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "predev": "node -r dotenv/config tools/check-firebase-env.mjs",
    "prebuild": "node -r dotenv/config tools/check-firebase-env.mjs",
    "prepreview": "node -r dotenv/config tools/check-firebase-env.mjs",
    "dev": "astro dev",
