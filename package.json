{
  "name": "launchpad",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.11.1",
    "npm": ">=11.6.2"
  },
  "scripts": {
    "predev": "node -r dotenv/config tools/check-firebase-env.mjs",
    "prebuild": "node -r dotenv/config tools/check-firebase-env.mjs",
    "prepreview": "node -r dotenv/config tools/check-firebase-env.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "ci:ts": "astro sync && tsc --noEmit",
    "ci:format": "prettier --check .",
    "ci:lint": "eslint ./src",
    "ci": "npm run ci:ts && npm run ci:lint && npm run ci:format",
    "fix:format": "prettier --write .",
    "fix:lint": "eslint ./src --fix",
    "fix": "npm run fix:lint && npm run fix:format",
    "verify": "npm run fix && npm run ci",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files && npm run verify",
    "firebase:push-rules": "firebase deploy --only firestore:rules",
    "db:seed": "node -r dotenv/config tools/db-seed.cjs",
    "astro": "astro",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.12",
    "@astrojs/react": "^5.0.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.4",
    "firebase": "^12.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-admin": "^13.10.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite-plugin-svgr": "^5.2.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "browserslist": [
    "chrome 87"
  ],
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,jsonc,md,yml,yaml}": "prettier --write"
  }
}
